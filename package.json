{
  "name": "corsair-hackathon",
  "private": true,
  "scripts": {
    "build": "dotenv -v NODE_ENV=production -- turbo build",
    "dev": "dotenv -- turbo dev",
    "db:generate": "dotenv -- turbo db:generate",
    "db:migrate": "dotenv -- turbo db:migrate",
    "db:check": "dotenv -- turbo db:check --filter=@repo/database",
    "db:seed": "dotenv -- turbo db:seed",
    "db:up": "docker compose up -d postgresdb",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
