# =============================================================================
# DATABASE — pick ONE: Local Docker OR Neon
# =============================================================================
#
# LOCAL (default for dev) — run: pnpm db:up
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev
DATABASE_URL_UNPOOLED=

# -----------------------------------------------------------------------------
# NEON (production / deploy) — https://console.neon.tech
# -----------------------------------------------------------------------------
# 1. Create a project (free tier is fine)
# 2. Open your project → Connect → copy connection strings
# 3. Pooled connection  → DATABASE_URL        (hostname contains -pooler)
# 4. Direct connection   → DATABASE_URL_UNPOOLED (hostname has NO -pooler)
# 5. Comment out the LOCAL DATABASE_URL line above
#
# Example shape (replace with YOUR strings from Neon dashboard):
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-name-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# After paste, run:  pnpm db:migrate   then   pnpm db:check
# =============================================================================

# API server
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000

# JWT (required for auth)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# Frontend — same-origin tRPC proxy in dev (see apps/web/next.config.js rewrites)
NEXT_PUBLIC_API_URL=/trpc

# Email (Brevo — transactional mail for sign-up / password reset)
BREVO_API_KEY=
EMAIL_PROVIDER=brevo
EMAIL_FROM=Thread <your-verified-sender@email.com>
EMAIL_SENDER_NAME=Thread

# Google OAuth (sign-in)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# Corsair (self-hosted Gmail integration)
CORSAIR_KEK=
CORSAIR_GMAIL_REDIRECT_URI=http://localhost:3000/api-connect/gmail/callback
CORSAIR_CALENDAR_REDIRECT_URI=http://localhost:3000/api-connect/calendar/callback
APP_URL=http://localhost:3000

# Logger (optional)
LOGGER_LEVEL=debug

# API docs in production (defaults to false outside development)
PUBLIC_OPENAPI_DOCS=true

# OpenAI — Priority inbox ranking + OpenAPI agent tools (optional)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Inbox — direct send bypasses the approval queue (keep false in production)
# THREAD_ALLOW_DIRECT_SEND=false
OPENAPI_DOCS_SECRET=

# Webhooks — shared secret for POST /webhooks/gmail and /webhooks/calendar.
# Required to enable the webhook receiver (Corsair/Google Pub/Sub push). Min 16 chars.
# Unset = receiver responds 503 and Thread falls back to on-demand sync.
CORSAIR_WEBHOOK_SECRET=

# Optional — demo login route (apps/web/app/api-auth/demo)
DEMO_LOGIN_ENABLED=false
DEMO_USER_EMAIL=demo@thread.dev
DEMO_USER_PASSWORD=DemoPass123!

# Optional — db seed script
SEED_USER_EMAIL=demo@thread.dev
SEED_DEMO_PASSWORD=DemoPass123!

# Cloudflare Turnstile — bot protection on email/password sign-up and sign-in
# Dashboard: https://dash.cloudflare.com/?to=/:account/turnstile
# Add hostnames: localhost, 127.0.0.1, and your production domain
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
