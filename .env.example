# =============================================================================
# Thread — Environment Variables
# Copy this file to .env and fill in all required values.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# Use a local Postgres instance or Neon (https://neon.tech — free tier).
# -----------------------------------------------------------------------------
# Local Docker:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev
# DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/dev

# Neon — Pooled connection (app runtime):
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# Neon — Direct connection (migrations only):
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# AUTH — JWT (generate with: openssl rand -base64 32)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-min-32-chars

# -----------------------------------------------------------------------------
# FRONTEND
# In dev, Next.js proxies /trpc → API. In production set to your API URL.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/trpc

# -----------------------------------------------------------------------------
# EMAIL — Brevo (https://brevo.com — free tier sends 300/day)
# Required for email verification and password reset.
# -----------------------------------------------------------------------------
BREVO_API_KEY=your-brevo-api-key
EMAIL_PROVIDER=brevo
EMAIL_FROM=Thread <noreply@yourdomain.com>
EMAIL_SENDER_NAME=Thread

# -----------------------------------------------------------------------------
# GOOGLE OAUTH — User sign-in with Google
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api-auth/google/callback
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# -----------------------------------------------------------------------------
# CORSAIR — Gmail + Calendar integration
# Sign up at: https://corsair.dev — free tier available
#
# CORSAIR_DEV_KEY: found at https://corsair.dev/dashboard → API Keys
#
# CORSAIR_KEK (Key Encryption Key): 32-byte secret used to encrypt OAuth
# tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# or:
#   openssl rand -base64 32
#
# Gmail OAuth redirect:    http://localhost:3000/api-connect/gmail/callback
# Calendar OAuth redirect: http://localhost:3000/api-connect/calendar/callback
# (add these exact URIs to your Google OAuth 2.0 client in Cloud Console)
# -----------------------------------------------------------------------------
CORSAIR_KEK=<base64-encoded-32-byte-key>
CORSAIR_DEV_KEY=ch_your-corsair-dev-key

# Headless MCP clients: Bearer token + X-Thread-User-Id header (falls back to CORSAIR_DEV_KEY)
# THREAD_MCP_API_KEY=thread_mcp_your-secret-key
# E2E only — mock Gmail send on queue approve (Playwright CI). Never enable in production.
# THREAD_E2E_MOCK_GMAIL=true
CORSAIR_GMAIL_REDIRECT_URI=http://localhost:3000/api-connect/gmail/callback
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OPENAI — AI agent + priority inbox ranking
# Optional — app works without it; agent and ranking features are disabled.
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-proj-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# LOGGER
# -----------------------------------------------------------------------------
LOGGER_LEVEL=debug

# -----------------------------------------------------------------------------
# API DOCS (Scalar UI at /docs)
# Set a secret to protect the docs endpoint in production.
# -----------------------------------------------------------------------------
PUBLIC_OPENAPI_DOCS=true
OPENAPI_DOCS_SECRET=

# -----------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE — Bot protection on auth forms
# Get keys at: https://dash.cloudflare.com → Turnstile
# Use test keys for local dev (always pass):
#   Site key:   1x00000000000000000000AA
#   Secret key: 1x0000000000000000000000000000000AA
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# -----------------------------------------------------------------------------
# DEMO LOGIN — One-click demo access (recommended for production/judging)
# Run `pnpm db:seed` first to create the demo user.
# Then enable this to expose /api-auth/demo?next=/inbox
# Set to false for production when demo is not needed.
# -----------------------------------------------------------------------------
DEMO_LOGIN_ENABLED=false
DEMO_USER_EMAIL=demo@thread.dev
DEMO_USER_PASSWORD=DemoPass123!

# -----------------------------------------------------------------------------
# SEED SCRIPT
# Used by `pnpm db:seed` to create the demo user.
# -----------------------------------------------------------------------------
SEED_USER_EMAIL=demo@thread.dev
SEED_DEMO_PASSWORD=DemoPass123!

# -----------------------------------------------------------------------------
# WEBHOOKS — Gmail push notifications (production only)
#
# Overview: Gmail delivers new-message notifications via Google Cloud Pub/Sub.
# When WEBHOOKS_BASE_URL is set, the app auto-registers a push subscription on
# Calendar OAuth and uses incremental history sync on Gmail webhooks.
#
# Setup steps (production):
#   1. Create a Google Cloud Pub/Sub topic:
#        gcloud pubsub topics create gmail-push
#   2. Add the Gmail service account as publisher:
#        gcloud pubsub topics add-iam-policy-binding gmail-push \
#          --member=serviceAccount:gmail-api-push@system.gserviceaccount.com \
#          --role=roles/pubsub.publisher
#   3. Create a push subscription pointing at your webhook URL:
#        gcloud pubsub subscriptions create gmail-push-sub \
#          --topic=gmail-push \
#          --push-endpoint=https://api.yourdomain.com/webhooks/gmail \
#          --ack-deadline=10
#   4. Note your topic name (format: projects/PROJECT_ID/topics/TOPIC_NAME)
#      and set CORSAIR_GMAIL_TOPIC_ID below.
#   5. Set CORSAIR_WEBHOOK_SECRET to a random string and pass it as the
#      X-Corsair-Webhook-Secret header (or configure your Pub/Sub subscription
#      to include it in the Authorization header).
#
# Local dev: leave WEBHOOKS_BASE_URL unset — polling fallback is used.
# -----------------------------------------------------------------------------
# WEBHOOKS_BASE_URL=https://api.yourdomain.com
# CORSAIR_WEBHOOK_SECRET=your-random-webhook-secret
# CORSAIR_GMAIL_TOPIC_ID=projects/YOUR_GCP_PROJECT/topics/gmail-push

# -----------------------------------------------------------------------------
# REDIS — Rate limits, persistent metrics counters, multi-instance SSE fan-out (optional)
# Falls back to in-memory if not set.
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# RATE_LIMIT_REQUIRE_REDIS=false

# -----------------------------------------------------------------------------
# OPENTELEMETRY — Distributed tracing (optional)
# Set OTEL_EXPORTER_OTLP_ENDPOINT to ship traces to Jaeger / Tempo / Honeycomb.
# Leave unset in local dev — SDK still initialises for in-process spans.
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=thread-api
