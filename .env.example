# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# API server
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000

# JWT (required for auth)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# Frontend — same-origin tRPC proxy in dev (see apps/web/next.config.js rewrites)
NEXT_PUBLIC_API_URL=/trpc

# Email (Brevo — transactional mail for sign-up / password reset)
BREVO_API_KEY=
EMAIL_PROVIDER=brevo
EMAIL_FROM=Thread <your-verified-sender@email.com>
EMAIL_SENDER_NAME=Thread

# Google OAuth (sign-in)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# Corsair (self-hosted Gmail integration)
CORSAIR_KEK=
CORSAIR_GMAIL_REDIRECT_URI=http://localhost:3000/api-connect/gmail/callback
APP_URL=http://localhost:3000

# Logger (optional)
LOGGER_LEVEL=debug

# API docs in production (set false + OPENAPI_DOCS_SECRET to protect /docs)
PUBLIC_OPENAPI_DOCS=true
OPENAPI_DOCS_SECRET=

# Optional — demo login route (apps/web/app/api-auth/demo)
DEMO_LOGIN_ENABLED=false
DEMO_USER_EMAIL=demo@thread.dev
DEMO_USER_PASSWORD=DemoPass123!

# Optional — db seed script
SEED_USER_EMAIL=demo@thread.dev
SEED_DEMO_PASSWORD=DemoPass123!
