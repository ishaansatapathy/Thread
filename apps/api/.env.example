# Copy values to repo root .env — API reads ../../.env via dotenv-cli in dev.

PORT=8000
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
BASE_URL=https://your-api.example.com
CLIENT_URL=https://your-app.example.com
JWT_SECRET=change-me-min-32-chars
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh
BREVO_API_KEY=
EMAIL_PROVIDER=brevo
EMAIL_FROM=Thread <noreply@your-verified-domain.com>
EMAIL_SENDER_NAME=Thread
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.example.com/api-auth/google/callback
CORSAIR_KEK=
CORSAIR_GMAIL_REDIRECT_URI=https://your-app.example.com/api-connect/gmail/callback
CORSAIR_CALENDAR_REDIRECT_URI=https://your-app.example.com/api-connect/calendar/callback
